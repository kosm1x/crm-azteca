{
  "name": "agentic-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agentic CRM for media ad sales — AI agents that do the CRM work for your sales team",
  "scripts": {
    "dev": "tsx engine/src/index.ts",
    "auth": "tsx engine/src/whatsapp-auth.ts",
    "build": "tsc --build",
    "build:container": "crm/container/build.sh",
    "start": "tsx engine/src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bootstrap": "tsx scripts/bootstrap.sh",
    "register-team": "tsx scripts/register-hierarchy.ts",
    "simulate": "tsx scripts/simulator/index.ts",
    "simulate:regression": "tsx scripts/simulator/index.ts --mode regression",
    "simulate:morning": "tsx scripts/simulator/index.ts --mode morning",
    "simulate:evening": "tsx scripts/simulator/index.ts --mode evening",
    "simulate:dry": "tsx scripts/simulator/index.ts --dry-run"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "dayjs": "^1.11.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^130.0.0",
    "link-preview-js": "^4.0.0",
    "nodemailer": "^6.9.0",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.7-alpha.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/nodemailer": "^6.4.0",
    "@types/uuid": "^9.0.0",
    "better-sqlite3": "^12.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
