# === NanoClaw Engine ===
ASSISTANT_NAME=CRM
TRIGGER_PATTERN=@CRM
CONTAINER_IMAGE=agentic-crm-agent:latest
TZ=America/Mexico_City
MAX_CONCURRENT_CONTAINERS=10

# === LLM Inference ===
INFERENCE_PRIMARY_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INFERENCE_PRIMARY_KEY=
INFERENCE_PRIMARY_MODEL=qwen-plus
INFERENCE_FALLBACK_URL=https://api.minimax.chat/v1
INFERENCE_FALLBACK_KEY=
INFERENCE_FALLBACK_MODEL=MiniMax-M2.5
INFERENCE_TIMEOUT_MS=30000
INFERENCE_MAX_TOKENS=4096

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=crm@apexmedios.com.mx
EMAIL_ENABLED=false

# === Google Calendar ===
GOOGLE_SERVICE_ACCOUNT_KEY=<base64-encoded-key>
GOOGLE_CALENDAR_ENABLED=false

# === Database ===
CRM_DB_PATH=./data/crm.db

# === Data Lake (Phase 2) ===
CUBO_MSSQL_HOST=
CUBO_MSSQL_USER=
CUBO_MSSQL_PASS=
CUBO_MSSQL_DB=
CUBO_SYNC_ENABLED=false

# === Embeddings ===
EMBEDDING_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# === Web Search ===
BRAVE_SEARCH_API_KEY=

# === WhatsApp ===
WHATSAPP_TRIGGER_WORD=@CRM

# ─── Dashboard / API JWT signing secret (REQUIRED) ───────────────────────────
# 32-byte hex from `openssl rand -hex 32`. PIN THIS — if unset, auth.ts
# generates a random secret per process start, which silently invalidates
# every previously-issued JWT (including mission-control's CRM_API_TOKEN)
# on every `systemctl restart agentic-crm`. See docs/LEARNINGS-2026-04-24.md.
DASHBOARD_JWT_SECRET=set_via_openssl_rand_hex_32

# Hindsight consolidation LLM (separate from primary inference).
# Defaults to INFERENCE_PRIMARY_MODEL. Override for cheaper/faster consolidation.
# qwen3-coder-plus benchmarked 6x faster than qwen3.6-plus for structured-merge tasks.
# HINDSIGHT_LLM_MODEL=qwen3-coder-plus
